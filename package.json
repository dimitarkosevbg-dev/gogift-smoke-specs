{
  "name": "gogift-smoke.spec.ts",
  "version": "1.2.0",
  "description": "End-to-end QA automation for shop.gogift.com — Playwright + TypeScript with visual regression, performance benchmarks, and CI sharding.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:performance": "playwright test --project=performance",
    "test:lighthouse": "playwright test --project=performance --grep @lighthouse",
    "test:perf:no-lighthouse": "playwright test --project=performance --grep-invert @lighthouse",
    "test:shard:1": "playwright test --grep @regression --shard=1/2",
    "test:shard:2": "playwright test --grep @regression --shard=2/2",
    "report": "playwright show-report",
    "report:merge": "playwright merge-reports --reporter html ./all-blob-reports"
  },
  "keywords": [
    "playwright",
    "qa",
    "automation",
    "visual-regression",
    "performance",
    "sharding"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "lighthouse": "^12.2.0",
    "playwright-lighthouse": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
